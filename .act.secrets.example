# Copy to .act.secrets and fill in real values.
# .act.secrets is gitignored — never commit it.
#
# Which secrets are needed per workflow:
#   ci.yml        — GITHUB_TOKEN (for GHCR push in the build job)
#   cd.yml        — AWS_*, PROD_* URLs  (skip if you only run ci.yml locally)
#   terraform.yml — AWS_*, TF_*
#   stress.yml    — PROD_APP_URL (or pass via workflow_dispatch input)

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here

# ── AWS (use fake values to skip real infra; real values needed for tf apply) ─
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1

# ── Terraform variables ────────────────────────────────────────────────────────
TF_DB_PASSWORD=testpassword
TF_REDIS_AUTH_TOKEN=testtoken12345678901234567890

# ── Production URLs (smoke tests in cd.yml) ────────────────────────────────────
PROD_APP_URL=http://localhost:3000
PROD_LLM_AGGREGATOR_URL=http://localhost:4001
PROD_USER_ANALYTICS_URL=http://localhost:4002
PROD_MODEL_WIDGET_URL=http://localhost:5174
