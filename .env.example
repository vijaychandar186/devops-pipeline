# Sentry
NEXT_PUBLIC_SENTRY_DSN=""   # From sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=""               # Same DSN — used server-side (not public)
SENTRY_AUTH_TOKEN=""        # From sentry.io/settings/auth-tokens/ — needed for source map upload at build time

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE?schema=public"

# Auth.js
AUTH_URL="http://localhost:3000"
AUTH_SECRET=""  # Generate with: openssl rand -base64 32

# GitHub OAuth
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=  # Required in prod — set a strong password

# PostgreSQL (used by docker-compose.prod.yml)
POSTGRES_USER=admin
POSTGRES_PASSWORD=

# pgAdmin
PGADMIN_DEFAULT_PASSWORD=

# Grafana
GRAFANA_ADMIN_PASSWORD=  # Generate with: openssl rand -base64 32
