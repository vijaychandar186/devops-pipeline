# act — run GitHub Actions locally
# https://github.com/nektos/act
#
# Install: brew install act   (Mac)  or  curl -s https://raw.githubusercontent.com/nektos/act/master/install.sh | sudo bash
# Run:     act                                    # all workflows
#          make act-ci                            # ci.yml only
#          act -W .github/workflows/ci.yml -j lint  # single job

# Use a full Ubuntu image — the micro default is missing most tools
-P ubuntu-latest=catthehacker/ubuntu:act-latest

# Secrets and env files (copy the .example files and fill in values)
--secret-file .act.secrets
--env-file .act.env

# Use the host Docker daemon (DooD — required in Codespaces)
--container-daemon-socket /var/run/docker.sock

# Keep containers after run for debugging (remove to auto-clean)
# --reuse
