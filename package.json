  "devDependencies": {
    "@types/node": "22.19.17",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "bun-types": "^1.3.12",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "postcss": "8.5.6",
    "prettier": "3.8.1",
