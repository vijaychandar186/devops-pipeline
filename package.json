    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.2.4",
    "eslint-config-next": "^16.0.7",
    "kbar": "^0.1.0-beta.45",
    "lucide-react": "^0.563.0",
    "motion": "^11.17.0",
    "next": "^16.0.7",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.7.15",
