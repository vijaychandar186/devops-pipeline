{
  "name": "devops-pipeline",
  "version": "1.0.0",
  "private": true,
  "author": {
    "name": "Vijay"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix && bun format",
    "lint:strict": "eslint --max-warnings=0 src",
    "format": "prettier --write .",
    "format:check": "prettier -c -w .",
    "prepare": "husky",
    "test": "bun test tests/unit/",
    "test:unit": "bun test tests/unit/",
    "test:integration": "bun test tests/integration/llm-aggregator.test.ts tests/integration/user-analytics.test.ts",
    "test:dev-stack": "bun test tests/integration/dev-stack.test.ts",
    "test:monitoring": "bun test tests/integration/monitoring.test.ts",
    "test:smoke": "bun test tests/smoke/",
    "test:infra": "bun test tests/infra/",
    "test:infra:ansible": "bun test tests/infra/ansible.test.ts",
    "test:infra:k8s": "bun test tests/infra/k8s.test.ts",
    "test:infra:terraform": "bun test tests/infra/terraform.test.ts",
    "test:infra:jenkins": "bun test tests/infra/jenkins.test.ts",
    "test:all": "bun test tests/unit/ && bun test tests/integration/llm-aggregator.test.ts tests/integration/user-analytics.test.ts && bun test tests/smoke/"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,tsx,ts,css,less,scss,sass,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
